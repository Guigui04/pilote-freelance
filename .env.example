# ---------------------------------------------------------------------------
# PILOTE — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs.
# ---------------------------------------------------------------------------

# --- Supabase (Base de données + Auth + Storage) ---
# Tableau de bord Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# Connexion Postgres directe (pour Drizzle migrations)
# Supabase > Project Settings > Database > Connection string (URI, mode "Transaction" / port 6543 pour le pooler)
DATABASE_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-eu-west-3.pooler.supabase.com:6543/postgres"
# Connexion directe (port 5432) pour drizzle-kit migrate/push
DIRECT_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-eu-west-3.pooler.supabase.com:5432/postgres"

# --- Identité du compte unique (mono-utilisateur) ---
# E-mail autorisé à se connecter (toute autre adresse est refusée)
ALLOWED_EMAIL="guillaume@exemple.com"

# --- Google OAuth (Auth + Calendar + Drive + Sheets) ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Notion ---
NOTION_TOKEN=""

# --- Google Gemini (IA, gratuit) ---
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""

# --- Resend (envoi d'e-mails, gratuit) ---
RESEND_API_KEY=""
RESEND_FROM_EMAIL="PILOTE <onboarding@resend.dev>"

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
